# Copy this file to .env.local and fill in your values

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/redhat-tracker?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this
